# MongoDB connection string
# Local:  mongodb://localhost:27017/24game
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/24game
MONGODB_URI=mongodb://localhost:27017/24game

# JWT signing secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: changing this invalidates all existing user sessions
JWT_SECRET=replace-with-64-byte-hex-secret

# Google OAuth Client ID (Google Cloud Console > APIs & Services > Credentials)
# Must match the client ID used by the frontend Google Sign-In button
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Server port
PORT=3000

# CORS allowed origin (* for dev, your domain in production)
CORS_ORIGIN=*
